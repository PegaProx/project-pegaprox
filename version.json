    "changelog": [
        "fix: ESXi datastore auto-detection from pyvmomi (VSAN, restricted shells) (#222)",
        "fix: replication job creation (get_cluster_resources → get_vm_resources) (#241)",
        "fix: cross-cluster migration per-NIC bridge mapping (#242)",
        "fix: cross-cluster migration per-storage mapping (EFI, TPM, multi-disk)",
        "fix: ESXi migration pvesm path validation — no more garbage filenames (#251, #244)",
        "fix: ESXi migration TMPDIR on target storage instead of local root",
        "fix: SSH WebSocket route mismatch behind reverse proxy (#221)",
        "fix: VNC console noVNC load timeout + auto-reconnect",
        "fix: SSL verification uses system CA store for custom CAs (#246)",
        "fix: cross-cluster replication error handling (#192)",
        "fix: cross-cluster replication storage mapping includes efidisk/tpmstate",
        "fix: RBAC — VM ACL users can see clusters without cluster.view (#248)",
        "fix: LDAP/OIDC users see info message instead of broken password form (#164)",
        "fix: site recovery network mapping uses full bridge mapping"
    ],
